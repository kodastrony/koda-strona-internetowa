# ── KODA Studio — Apache configuration (OVH shared hosting) ────────────────
# This file is copied verbatim into out/ during `next build` (static export),
# then uploaded to OVH www/ via FTP. All directives apply to the document root.

# ── HTTPS redirect ──────────────────────────────────────────────────────────
# Force every HTTP request to HTTPS. OVH shared hosting has SSL enabled via
# the control panel; this ensures the redirect is enforced at the app level too.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── Security headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Prevent MIME-type sniffing (e.g. serving JS as text/html).
  Header always set X-Content-Type-Options "nosniff"

  # Disallow embedding in frames (clickjacking protection).
  # Redundant with frame-ancestors in CSP, but kept for older browser support.
  Header always set X-Frame-Options "DENY"

  # Send full URL to same-origin, only origin to cross-origin HTTPS, nothing to HTTP.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Restrict access to sensitive browser APIs — this site uses none of them.
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # HSTS — enforce HTTPS for 1 year. Add includeSubDomains / preload only after
  # verifying ALL subdomains are HTTPS-ready.
  Header always set Strict-Transport-Security "max-age=31536000"

  # Content-Security-Policy — tailored to KODA's static Next.js export:
  #   • script-src: 'unsafe-inline' needed for Next.js hydration JSON blobs
  #     (__NEXT_DATA__) and dynamic chunk imports in the static export.
  #   • style-src: 'unsafe-inline' needed because Framer Motion applies animation
  #     state as inline `style` attributes (cannot be hashed).
  #   • connect-src: includes formsubmit.co — the lead form submits via fetch()
  #     (multipart, with the file). fetch is governed by connect-src.
  #   • form-action: also includes formsubmit.co — the <form> keeps its native
  #     action/method/enctype as a no-JS fallback (native POST = form-action).
  #   • object-src/frame-src 'none': the site embeds no plugins or iframes.
  #   • frame-ancestors 'none' replaces X-Frame-Options for CSP-aware browsers.
  Header always set Content-Security-Policy "\
default-src 'self'; \
script-src 'self' 'unsafe-inline'; \
style-src 'self' 'unsafe-inline'; \
img-src 'self' data:; \
font-src 'self'; \
connect-src 'self' https://formsubmit.co; \
object-src 'none'; \
frame-src 'none'; \
frame-ancestors 'none'; \
base-uri 'self'; \
form-action 'self' https://formsubmit.co"
</IfModule>

# ── MIME types ────────────────────────────────────────────────────────────────
# Guarantee correct image MIME regardless of OVH's mime.types. The portfolio
# screenshots ship as .webp, and X-Content-Type-Options: nosniff is set above —
# so an image served without a proper image/* type could be refused. mod_mime is
# always present (no <IfModule> needed); AddType is a safe no-op if already mapped.
AddType image/webp .webp
AddType image/avif .avif
# Portfolio signature-animation clips ship as .mp4 (H.264) — same nosniff reason.
AddType video/mp4 .mp4

# ── Custom error documents ───────────────────────────────────────────────────
# Next.js static export generates out/404.html; Apache uses it for any 404.
ErrorDocument 404 /404.html

# ── Caching ──────────────────────────────────────────────────────────────────
# ⚠️ Turbopack does NOT content-hash its JS/CSS chunk filenames (verified: a real
# code change renamed ZERO chunks across two clean builds). So .js/.css CANNOT be
# cached "immutable" — returning visitors would be pinned to stale code/styles for
# up to a year (they'd never see a deploy without a hard refresh). Only next/font
# files under _next/static/media/ have true content-hashed names → safe forever.
# Split is purely by extension (no <If>/mod_setenvif → no 500 risk on OVH shared).
<IfModule mod_headers.c>
  # Fonts — content-hashed names (next/font), bytes never change → cache forever.
  <FilesMatch "\.(woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # JS/CSS — NOT content-hashed (filenames stay stable across deploys). Short cache
  # keeps repeat views fast (in-window cache hits, then cheap conditional 304s)
  # while guaranteeing a deploy reaches returning visitors within ~10 minutes.
  <FilesMatch "\.(js|css|mjs)$">
    Header set Cache-Control "public, max-age=600, must-revalidate"
  </FilesMatch>

  # Images / icons (favicon, logos, og) — fixed or hashed names; 1-day TTL with
  # revalidation is a safe middle ground that still picks up a deploy promptly.
  <FilesMatch "\.(ico|png|jpe?g|webp|avif|svg|gif)$">
    Header set Cache-Control "public, max-age=86400, must-revalidate"
  </FilesMatch>

  # Video clips (portfolio) — stable filenames; 1-day TTL with revalidation so a
  # redeploy that swaps a clip still reaches returning visitors promptly.
  <FilesMatch "\.(mp4|webm)$">
    Header set Cache-Control "public, max-age=86400, must-revalidate"
  </FilesMatch>

  # HTML pages — always revalidate so users get the latest deploy immediately.
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # Metadata files — cache for 1 day (robots.txt / sitemap.xml rarely change).
  <FilesMatch "(robots\.txt|sitemap\.xml)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

# ── Compression (gzip) ───────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
  AddOutputFilterByType DEFLATE application/json text/xml image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2 font/woff
</IfModule>

# ── Compression (Brotli — preferred when available; gzip above is the fallback) ─
# Brotli beats gzip ~15-20% on text (notably the ~232 KB-gzip three.js chunk).
# Wrapped in <IfModule>: a pure no-op if OVH lacks mod_brotli (block skipped),
# and browsers that don't send 'br' use the mod_deflate gzip filter above.
# WOFF2 is already Brotli-compressed internally → intentionally NOT re-compressed.
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/json text/xml image/svg+xml
</IfModule>
